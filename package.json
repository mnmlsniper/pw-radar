{
  "name": "pw-radar",
  "version": "0.1.0",
  "description": "API test coverage against an OpenAPI/Swagger spec — Playwright recorder + report CLI (TypeScript port of swagger-coverage)",
  "type": "module",
  "license": "Apache-2.0",
  "keywords": [
    "playwright",
    "api",
    "coverage",
    "async",
    "testing",
    "network",
    "pw"
  ],
  "bin": {
    "swagger-coverage-ts": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./playwright": {
      "types": "./dist/playwright/index.d.ts",
      "import": "./dist/playwright/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test tests/*.test.ts",
    "test:watch": "node --import tsx --watch --test tests/*.test.ts",
    "coverage": "c8 --reporter=text --reporter=lcov node --import tsx --test tests/*.test.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.40.0"
  },
  "peerDependenciesMeta": {
    "@playwright/test": {
      "optional": true
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.0.0",
    "c8": "^10.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0"
  }
}
